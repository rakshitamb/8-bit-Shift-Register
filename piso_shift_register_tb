`timescale 1ns/1ps

module piso_shift_register_tb;

reg clk;
reg load;
reg [7:0] parallel_in;
wire serial_out;

piso_shift_register uut(
    .clk(clk),
    .load(load),
    .parallel_in(parallel_in),
    .serial_out(serial_out)
);

always #5 clk = ~clk;   // clock generator
initial
begin
    clk = 0;
    load = 1;
    parallel_in = 8'b11010110;

    #10 load = 0;   // start shifting

    #100 $stop;
end

endmodule
